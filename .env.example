PORT=3000
APP_BASE_URL=https://your-public-domain.example
SESSION_TTL_SECONDS=300
REQUEST_JWT_TTL_SECONDS=300

# Request object parity fields
VERIFIER_ISSUER=https://your-public-domain.example
VERIFIER_REDIRECT_URI=https://your-public-domain.example/check-in/complete
REQUEST_AUDIENCE=https://self-issued.me/v2
VERIFIER_CLIENT_NAME=SkyLink Self Check-in
VERIFIER_LOGO_URI=https://your-public-domain.example/logo.png
VERIFIER_POLICY_URI=https://your-public-domain.example/privacy
VERIFIER_CLIENT_URI=https://your-public-domain.example
VERIFIER_REDIRECT_URIS=https://your-public-domain.example/check-in/complete

# DCQL request profile
REQUEST_DCQL_CREDENTIAL_ID=booking
REQUEST_DCQL_VCT_VALUES=https://issuer.example/booking
REQUEST_DCQL_CLAIMS=[{"id":"booking_reference","path":["booking_reference"]},{"id":"given_name","path":["given_name"]},{"id":"family_name","path":["family_name"]},{"id":"flight_number","path":["flight_number"]},{"id":"departure_airport","path":["departure_airport"]},{"id":"arrival_airport","path":["arrival_airport"]},{"id":"departure_time","path":["departure_time"]}]

# Verification requirements
REQUIRED_CLAIMS=booking_reference,family_name,flight_number
ALLOW_REMOTE_JWKS=true
TRUSTED_ISSUER_JWKS={}

# Request object signing key
REQUEST_SIGNING_PRIVATE_JWK={"kty":"EC","crv":"P-256","x":"tjfm-1mQPGNPFMT9EXN5C0-JKjnkW9AfYeq7X1d0xi0","y":"0OLzpn1QC3p_dwccDX3mY4pnxRZ6u7etNq5dGXdu4pc","d":"H8kFstvct5rgaloz6RHdM_5hNa3mIpEzJH2pqPqmjUM"}
REQUEST_SIGNING_KID=verifier-demo-kid
REQUEST_SIGNING_ALG=ES256
LOG_RAW_VP_TOKEN=false
